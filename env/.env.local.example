# Base de datos (PostgreSQL instalado en tu máquina o docker-compose --profile local-db)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orden_trabajo_microservice
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=cambiar_password_seguro

# Keycloak - Desarrollo
KEYCLOAK_ISSUER_URI=https://desa-sso-etimet.taurus-ts.com/realms/Etimet
KEYCLOAK_JWK_SET_URI=https://desa-sso-etimet.taurus-ts.com/realms/Etimet/protocol/openid-connect/certs

# RabbitMQ - Desarrollo (docker-compose --profile local-rabbit o servidor local)
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBIT_VHOST=/
RABBIT_SSL_ENABLED=false

# Puerto del microservicio en local
SERVER_PORT=8081